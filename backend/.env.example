# ===== Core =====
# Port the backend listens on
PORT=4000

# ===== Database (libSQL / SQLite) =====
# Local dev uses a SQLite file; production uses Turso (free SQLite-compatible).
#   local: file:./database/interview.db
#   prod:  libsql://<your-db>.turso.io   (create with `turso db create`)
DATABASE_URL=file:./database/interview.db
# Required only for a remote Turso URL (turso db tokens create <db>).
DATABASE_AUTH_TOKEN=

# Public base URL of the frontend app (used to build interview links).
# Interview links look like: {PUBLIC_SITE_URL}/interview/{session_token}
# In production set this to your Netlify site URL.
PUBLIC_SITE_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173

# Comma-separated list of allowed CORS origins (the frontend origin)
CORS_ORIGINS=http://localhost:5173

# ===== Telegram bot (built into this Node server) =====
# Token from @BotFather. Enables /start -> interview link and result delivery.
TELEGRAM_BOT_TOKEN=
# Secret Telegram sends back on each webhook call (production). Pick a long random string.
TELEGRAM_WEBHOOK_SECRET=
# 'polling' for local dev (no public URL needed), 'webhook' for production, 'off' to disable.
TELEGRAM_MODE=polling

# ===== OpenAI =====
# Your OpenAI API key. NEVER expose this to the frontend.
OPENAI_API_KEY=

# Model used for the interviewer + evaluation reasoning
OPENAI_CHAT_MODEL=gpt-4o
# Model used for speech-to-text transcription
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
# Model used for text-to-speech
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Voice used for TTS
OPENAI_TTS_VOICE=alloy

# ===== Mock mode =====
# When true, NO real OpenAI calls are made. Canned questions, transcripts,
# and evaluations are returned. Great for local dev / CI / demos.
MOCK_MODE=true

# ===== Telegram bot result webhook =====
# The endpoint on the Telegram recruiter bot backend (FastAPI) that receives
# results. The real bot webhook runs on port 8000 at /api/interview-result.
# (For offline testing without the real bot, use the mock on port 9000:
#  http://localhost:9000/interview-result — see tools/mock-telegram-bot.js)
TELEGRAM_BOT_RESULT_ENDPOINT=http://localhost:8000/api/interview-result

# Shared secret sent as `Authorization: Bearer <secret>` to the webhook.
# MUST match RESULT_WEBHOOK_SECRET in the Telegram bot's .env.
RESULT_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Optional: where to ping the bot when an interview STARTS. If omitted it is
# derived from TELEGRAM_BOT_RESULT_ENDPOINT (…/interview-result -> …/interview-started).
# TELEGRAM_BOT_STARTED_ENDPOINT=http://localhost:8000/api/interview-started

# ===== Admin =====
# Secret required to create interview sessions via the admin API.
# The Telegram bot uses this when minting a new interview link.
ADMIN_API_SECRET=replace-with-another-long-random-secret

# ===== Interview tuning =====
# Approximate target interview length (minutes) and question budget.
INTERVIEW_MAX_MINUTES=15
INTERVIEW_MIN_QUESTIONS=10
INTERVIEW_MAX_QUESTIONS=15

# Whether the completion screen shows the result (Pass/Fail/Needs Review +
# criteria) to the candidate. Set false to keep results recruiter-only.
SHOW_RESULT_TO_CANDIDATE=true
