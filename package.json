{
  "name": "auto-interview",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Automated AI Chinese interview + Telegram bot — one unified project (Netlify + libSQL/SQLite)",
  "scripts": {
    "dev": "node tools/dev.js",
    "dev:web": "vite",
    "dev:server": "node --watch backend/src/index.js",
    "build": "vite build",
    "start": "node backend/src/index.js",
    "set-webhook": "node backend/src/scripts/set-webhook.mjs",
    "seed": "node -e \"import('./backend/src/db.js').then(async m=>{await m.initSchema();const s=await import('./backend/src/store.js');await s.ensureSampleSession();console.log('seeded');process.exit(0)})\""
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  }
}
